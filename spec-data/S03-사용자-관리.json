{
  "id": "S03",
  "name": "사용자 관리",
  "route": "/users",
  "description": "시스템 사용자 CRUD 및 역할/상태 관리",
  "accessRole": "ADMIN",
  "layout": "AdminLayout",
  "screenDesign": "docs/screen-design/12-사용자-관리.md",
  "functionalSpec": "docs/functional-spec/02-사용자-관리.md",
  "sourceFile": "src/app/users/page.tsx",
  "components": [
    {
      "id": "S03-C01",
      "name": "PageHeader",
      "type": "header",
      "description": "타이틀: '사용자 관리'. action: '사용자 추가' 버튼 → CreateUserDialog 열기",
      "uiIndex": 1
    },
    {
      "id": "S03-C02",
      "name": "통계 카드 그리드",
      "type": "stats",
      "description": "총 사용자/활성 사용자/정지 사용자/비활성 사용자 4개 StatsCard",
      "uiIndex": 2
    },
    {
      "id": "S03-C03",
      "name": "UserFilterBar",
      "type": "filter",
      "description": "상태/역할/검색어/시작일/종료일 필터. 활성 필터 수 Badge. 초기화 버튼",
      "uiIndex": 3
    },
    {
      "id": "S03-C04",
      "name": "사용자 DataTable",
      "type": "table",
      "description": "서버사이드 페이지네이션 DataTable. 컬럼: Avatar+닉네임+이메일/역할/상태/가입일/액션",
      "uiIndex": 4
    },
    {
      "id": "S03-C05",
      "name": "CreateUserDialog",
      "type": "dialog",
      "description": "사용자 생성 다이얼로그",
      "uiIndex": 5
    },
    {
      "id": "S03-C06",
      "name": "UserDetailDialog",
      "type": "dialog",
      "description": "사용자 상세 정보 조회 다이얼로그",
      "uiIndex": 6
    },
    {
      "id": "S03-C07",
      "name": "EditUserDialog",
      "type": "dialog",
      "description": "사용자 정보 수정 다이얼로그",
      "uiIndex": 7
    },
    {
      "id": "S03-C08",
      "name": "ConfirmDialog",
      "type": "dialog",
      "description": "역할 변경/상태 변경/삭제 확인 다이얼로그 (destructive 포함)",
      "uiIndex": 8
    }
  ],
  "apis": [
    {
      "method": "GET",
      "path": "/admin/users",
      "description": "사용자 목록 조회 (페이지네이션, 필터)"
    },
    {
      "method": "POST",
      "path": "/admin/users",
      "description": "사용자 생성"
    },
    {
      "method": "PATCH",
      "path": "/admin/users/{id}",
      "description": "사용자 정보 수정"
    },
    {
      "method": "PATCH",
      "path": "/admin/users/{id}/status",
      "description": "사용자 상태 변경 (ACTIVE/SUSPENDED/INACTIVE)"
    },
    {
      "method": "PATCH",
      "path": "/admin/users/{id}/role",
      "description": "사용자 역할 변경"
    },
    {
      "method": "DELETE",
      "path": "/admin/users/{id}",
      "description": "사용자 삭제"
    }
  ],
  "hooks": [
    "useUserStats()",
    "useUsers(filters, pagination)",
    "useDeleteUser()",
    "useUpdateUserStatus()",
    "useUpdateUserRole()"
  ],
  "states": ["default", "loading", "empty", "filtered"]
}
