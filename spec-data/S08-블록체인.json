{
  "id": "S08",
  "name": "블록체인",
  "route": "/blockchain",
  "description": "블록체인 컨트랙트 목록 조회 및 트랜잭션/엔트리 해시 검색 (UI 미구현)",
  "accessRole": "ADMIN",
  "layout": "AdminLayout",
  "screenDesign": "docs/screen-design/16-블록체인.md",
  "functionalSpec": "docs/functional-spec/06-블록체인-관리.md",
  "sourceFile": "src/app/blockchain/page.tsx",
  "implementationStatus": "UI 미구현 (백엔드 API 존재)",
  "components": [
    {
      "id": "S08-C01",
      "name": "PageHeader",
      "type": "header",
      "description": "타이틀: '블록체인', 설명: '블록체인 컨트랙트와 트랜잭션을 관리합니다'",
      "uiIndex": 1
    },
    {
      "id": "S08-C02",
      "name": "통계 카드 그리드",
      "type": "stats",
      "description": "총 컨트랙트/배포 성공/배포 대기/배포 실패 4개 StatsCard",
      "uiIndex": 2
    },
    {
      "id": "S08-C03",
      "name": "트랜잭션 해시 검색",
      "type": "search",
      "description": "0x... 형태 트랜잭션 해시 입력 후 조회 버튼",
      "uiIndex": 3
    },
    {
      "id": "S08-C04",
      "name": "엔트리 ID 검색",
      "type": "search",
      "description": "엔트리 ID 입력 후 조회 버튼",
      "uiIndex": 4
    },
    {
      "id": "S08-C05",
      "name": "컨트랙트 DataTable",
      "type": "table",
      "description": "서버사이드 페이지네이션. 컬럼: 게임명/컨트랙트 주소(font-mono 축약)/네트워크/배포 상태/배포일/액션",
      "uiIndex": 5
    },
    {
      "id": "S08-C06",
      "name": "트랜잭션 상세 Dialog",
      "type": "dialog",
      "description": "TX해시/블록번호/상태/가스사용량/타임스탬프/From/To/이벤트 로그 표시",
      "uiIndex": 6
    },
    {
      "id": "S08-C07",
      "name": "엔트리 상태 Dialog",
      "type": "dialog",
      "description": "엔트리ID/게임/사용자/상태/TX해시/참가시간 표시",
      "uiIndex": 7
    }
  ],
  "apis": [
    {
      "method": "GET",
      "path": "/admin/blockchain/contracts",
      "description": "컨트랙트 목록 조회"
    },
    {
      "method": "GET",
      "path": "/admin/blockchain/transactions/{hash}",
      "description": "트랜잭션 해시로 상세 조회"
    },
    {
      "method": "GET",
      "path": "/admin/blockchain/entries/{entryId}",
      "description": "엔트리 ID로 블록체인 상태 조회"
    }
  ],
  "hooks": [
    "useBlockchainStats()",
    "useContracts(pagination)",
    "useTransactionByHash(hash)",
    "useEntryStatus(entryId)"
  ],
  "states": ["default", "loading", "search-result"]
}
