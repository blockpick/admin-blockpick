{
  "id": "S04",
  "name": "게임 관리",
  "route": "/games",
  "description": "게임 생성/수정/삭제 및 상태 관리. 2-Step 생성 다이얼로그 포함",
  "accessRole": "ADMIN",
  "layout": "AdminLayout",
  "screenDesign": "docs/screen-design/13-게임-관리.md",
  "functionalSpec": "docs/functional-spec/03-게임-관리.md",
  "sourceFile": "src/app/games/page.tsx",
  "components": [
    {
      "id": "S04-C01",
      "name": "PageHeader",
      "type": "header",
      "description": "타이틀: '게임 관리'. action: '게임 생성' 버튼 → CreateGameDialog 열기",
      "uiIndex": 1
    },
    {
      "id": "S04-C02",
      "name": "통계 카드 그리드",
      "type": "stats",
      "description": "전체 게임/진행중/예정/종료 4개 StatsCard",
      "uiIndex": 2
    },
    {
      "id": "S04-C03",
      "name": "GameFilterBar",
      "type": "filter",
      "description": "게임 타입/상태/카테고리/검색어/시작일/종료일 필터",
      "uiIndex": 3
    },
    {
      "id": "S04-C04",
      "name": "게임 DataTable",
      "type": "table",
      "description": "서버사이드 페이지네이션. 컬럼: 게임명/타입/상태/참가비/기간/상품수/액션",
      "uiIndex": 4
    },
    {
      "id": "S04-C05",
      "name": "CreateGameDialog",
      "type": "dialog",
      "description": "2-Step 게임 생성 다이얼로그. Step1: 기본정보, Step2: 상품연결 + 블록체인 배포",
      "uiIndex": 5
    },
    {
      "id": "S04-C06",
      "name": "GameDetailDialog",
      "type": "dialog",
      "description": "게임 상세 정보 조회 (기본정보/참가보상/시간/그리드/옵션/연결상품/블록체인)",
      "uiIndex": 6
    },
    {
      "id": "S04-C07",
      "name": "EditGameDialog",
      "type": "dialog",
      "description": "게임 정보 수정 다이얼로그",
      "uiIndex": 7
    },
    {
      "id": "S04-C08",
      "name": "ConfirmDialog",
      "type": "dialog",
      "description": "강제 종료/정산/삭제 확인 다이얼로그",
      "uiIndex": 8
    }
  ],
  "apis": [
    {
      "method": "GET",
      "path": "/admin/games",
      "description": "게임 목록 조회 (페이지네이션, 필터)"
    },
    {
      "method": "POST",
      "path": "/admin/games",
      "description": "게임 생성"
    },
    {
      "method": "PATCH",
      "path": "/admin/games/{id}",
      "description": "게임 수정"
    },
    {
      "method": "DELETE",
      "path": "/admin/games/{id}",
      "description": "게임 삭제"
    },
    {
      "method": "POST",
      "path": "/admin/games/{id}/force-end",
      "description": "게임 강제 종료"
    },
    {
      "method": "POST",
      "path": "/admin/games/{id}/settle",
      "description": "게임 정산"
    }
  ],
  "hooks": [
    "useGameStats()",
    "useGames(filters, pagination)",
    "useCreateGame()",
    "useUpdateGame()",
    "useDeleteGame()",
    "useForceEndGame()",
    "useSettleGame()"
  ],
  "states": ["default", "loading", "empty", "filtered"]
}
